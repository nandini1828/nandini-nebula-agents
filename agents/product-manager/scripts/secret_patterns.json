{
  "bearer_token": {
    "type": "regex",
    "pattern": "(?:Authorization:\\s*Bearer\\s+(?!\\*\\*\\*REDACTED\\*\\*\\*|\\$)[A-Za-z0-9._~+/=-]{20,}|--token=(?!\\$|\\*\\*\\*)[A-Za-z0-9._~+/=-]{20,})",
    "flags": ["ignorecase"]
  },
  "cookie": {
    "type": "regex",
    "pattern": "(?:Cookie|Set-Cookie):\\s*[A-Za-z0-9_=-]+=(?!\\*\\*\\*REDACTED\\*\\*\\*|\\$)[A-Za-z0-9+/=._-]{16,}",
    "flags": ["ignorecase"]
  },
  "private_key": {
    "type": "regex",
    "pattern": "-----BEGIN\\s+(?:RSA|OPENSSH|EC)\\s+PRIVATE\\s+KEY-----",
    "flags": []
  },
  "raw_connection_string": {
    "type": "regex",
    "pattern": "(?:Password=(?!\\$|\\*\\*\\*)[^;\\s]+;|(?:postgres|mongodb)://[^:\\s]+:(?!\\*\\*\\*)[^@\\s]+@)",
    "flags": ["ignorecase"]
  },
  "access_key": {
    "type": "regex",
    "pattern": "(?:AKIA[0-9A-Z]{16}|aws_secret_access_key\\s*=\\s*(?!\\$|\\*\\*\\*)[A-Za-z0-9/+=]{24,}|xoxb-[0-9]{10,}-[0-9]{10,}-[A-Za-z0-9]{20,})",
    "flags": ["ignorecase"]
  },
  "env_dump": {
    "type": "multi_line_scanner",
    "anchor_regex": "^[A-Z_][A-Z0-9_]*=.+$",
    "window_lines": 5,
    "min_matches_in_window": 2,
    "secondary_match_classes": ["bearer_token", "private_key", "raw_connection_string", "access_key"]
  },
  "env_file_contents": {
    "type": "multi_line_scanner",
    "anchor_regex": "(?:^|/|\\s)\\.env(?:\\s|$)",
    "window_lines": 5,
    "min_matches_in_window": 1,
    "secondary_match_classes": ["bearer_token", "private_key", "raw_connection_string", "access_key"]
  }
}
